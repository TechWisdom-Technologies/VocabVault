// VocabVault — Prisma Schema
// Database: Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum UserPlan {
  FREE
  PRO
}

enum UserRole {
  USER
  ADMIN
}

enum WordProgressStatus {
  IN_PROGRESS
  RETRY
  COMPLETED
  FAILED
}

enum FeedbackCategory {
  BUG_REPORT
  FEATURE_REQUEST
  STAGE_FEEDBACK
  GENERAL
  OTHER
}

enum FeedbackStatus {
  NEW
  IN_REVIEW
  RESOLVED
  DISMISSED
}

// ─── Users ───────────────────────────────────────────────

model User {
  id                  String   @id @default(uuid())
  firebaseUid         String   @unique @map("firebase_uid")
  email               String   @unique
  name                String?
  avatarUrl           String?  @map("avatar_url")
  dob                 DateTime? @db.Date
  age                 Int?
  nationality         String?
  phone               String?
  profession          String?
  reason              String?
  plan                UserPlan @default(FREE)
  maxUnlockedIndex    Int      @default(0) @map("max_unlocked_index")
  role                UserRole @default(USER)
  stripeCustomerId    String?  @map("stripe_customer_id")
  stripePaymentId     String?  @map("stripe_payment_id")
  onboardingComplete  Boolean  @default(false) @map("onboarding_complete")
  dayCount            Int      @default(0) @map("day_count")
  currentStreak       Int      @default(0) @map("current_streak")
  longestStreak       Int      @default(0) @map("longest_streak")
  totalScore          Int      @default(0) @map("total_score")
  wordsLearned        Int      @default(0) @map("words_learned")
  isLocked            Boolean  @default(false) @map("is_locked")
  lockReason          String?  @map("lock_reason")
  rulesAcknowledged   Boolean  @default(false) @map("rules_acknowledged")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  dailyWordSets       DailyWordSet[]
  wordProgress        WordProgress[]
  deviceSessions      DeviceSession[]
  activityLogs        ActivityLog[]
  leaderboardEntry    LeaderboardCache?
  feedback            Feedback[]
  adminLogs           AdminLog[]       @relation("AdminActions")
  suspiciousEvents    SuspiciousEvent[]
  follows             Follow[]         @relation("Follower")
  followers           Follow[]         @relation("Following")
  streakRewards       StreakReward[]
  achievements        Achievement[]
  sentChallenges      Challenge[]      @relation("Challenger")
  receivedChallenges  Challenge[]      @relation("Challenged")
  notifications       Notification[]

  @@map("users")
}

// ─── Follows (one-way) ───────────────────────────────────

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

// ─── Words ───────────────────────────────────────────────

model Word {
  id                    String   @id @default(uuid())
  word                  String   @unique
  phonetic              String
  partOfSpeech          String   @map("part_of_speech")
  definition            String   @db.Text
  tenseForms            Json     @map("tense_forms")
  pronunciationAudioUrl String?  @map("pronunciation_audio_url")
  definitionAudioUrl    String?  @map("definition_audio_url")
  synonyms              Json     // [{ word, sentence }] — 3 entries
  antonyms              Json     // [{ word, sentence }] — 3 entries
  sentences             Json     // [{ tense, sentence }] — 6 entries
  articles              Json     // [{ title, content }] — 3 articles ~50 words
  paragraph             String   @db.Text // 200+ word paragraph for Stage 8
  audioClipUrls         Json     @map("audio_clip_urls") // [{ accent, url }] — 3 clips
  correctAudioCounts    Json     @map("correct_audio_counts") // [{ accent, count }]
  paragraphTargetCount  Int      @map("paragraph_target_count")
  paragraphSynonymCount Int      @map("paragraph_synonym_count")
  paragraphAntonymCount Int      @map("paragraph_antonym_count")
  recall1Questions      Json?    @map("recall_1_questions") // Custom Qs for Stage 4
  recall2Pairs          Json?    @map("recall_2_pairs")     // Custom Matching for Stage 6
  orderIndex            Int      @unique @map("order_index")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  wordProgress WordProgress[]
  feedback     Feedback[]
  challenges   Challenge[]

  @@map("words")
}

// ─── Daily Word Sets ─────────────────────────────────────

model DailyWordSet {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  date           DateTime @db.Date
  wordIds        Json     @map("word_ids") // Array of up to 5 word UUIDs
  completedCount Int      @default(0) @map("completed_count")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_word_sets")
}

// ─── Word Progress ───────────────────────────────────────

model WordProgress {
  id            String              @id @default(uuid())
  userId        String              @map("user_id")
  wordId        String              @map("word_id")
  date          DateTime            @db.Date
  status        WordProgressStatus  @default(IN_PROGRESS)
  totalScore    Int                 @default(0) @map("total_score")
  currentStage  Int                 @default(1) @map("current_stage")
  sessionState  Json?               @map("session_state") // Exact resume point data
  flaggedStages Json?               @map("flagged_stages") // Array of stage numbers to retry
  startedAt     DateTime            @default(now()) @map("started_at")
  completedAt   DateTime?           @map("completed_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  word        Word         @relation(fields: [wordId], references: [id], onDelete: Cascade)
  stageScores StageScore[]

  @@unique([userId, wordId])
  @@index([userId])
  @@index([startedAt])
  @@map("word_progress")
}

// ─── Stage Scores ────────────────────────────────────────

model StageScore {
  id               String   @id @default(uuid())
  wordProgressId   String   @map("word_progress_id")
  stageNumber      Int      @map("stage_number")
  score            Int      @default(0)
  maxScore         Int      @default(10) @map("max_score")
  timeSpentSeconds Int      @default(0) @map("time_spent_seconds")
  attempts         Int      @default(1)
  passed           Boolean  @default(false)
  responseData     Json?    @map("response_data") // Quiz answers, writing text, AI responses
  createdAt        DateTime @default(now()) @map("created_at")

  wordProgress WordProgress @relation(fields: [wordProgressId], references: [id], onDelete: Cascade)

  @@index([wordProgressId])
  @@index([createdAt])
  @@map("stage_scores")
}

// ─── Device Sessions ─────────────────────────────────────

model DeviceSession {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  sessionToken    String   @unique @map("session_token")
  deviceName      String   @map("device_name")
  deviceType      String   @map("device_type") // browser, mobile, desktop
  os              String
  lastActive      DateTime @default(now()) @map("last_active")
  ipAddress       String   @map("ip_address")
  locationCity    String?  @map("location_city")
  locationCountry String?  @map("location_country")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_sessions")
}

// ─── Activity Log ────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  actionType  String   @map("action_type") // WORD_STARTED, STAGE_COMPLETED, WORD_COMPLETED, etc.
  wordId      String?  @map("word_id")
  stageNumber Int?     @map("stage_number")
  score       Int?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_log")
}

// ─── Leaderboard Cache ───────────────────────────────────

model LeaderboardCache {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  totalScore    Int      @default(0) @map("total_score")
  wordsLearned  Int      @default(0) @map("words_learned")
  currentStreak Int      @default(0) @map("current_streak")
  rank          Int      @default(0)
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leaderboard_cache")
}

// ─── Feedback ────────────────────────────────────────────

model Feedback {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  category    FeedbackCategory
  subject     String           @db.VarChar(100)
  message     String           @db.VarChar(1000)
  wordId      String?          @map("word_id")
  stageNumber Int?             @map("stage_number")
  status      FeedbackStatus   @default(NEW)
  adminNote   String?          @map("admin_note") @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word? @relation(fields: [wordId], references: [id], onDelete: SetNull)

  @@map("feedback")
}

// ─── Admin Logs ──────────────────────────────────────────

model AdminLog {
  id          String   @id @default(uuid())
  adminUserId String   @map("admin_user_id")
  action      String   // LOCK_ACCOUNT, OVERRIDE_SCORE, RESET_WORD, etc.
  targetType  String   @map("target_type") // USER, WORD, FEEDBACK, etc.
  targetId    String   @map("target_id")
  reason      String   @db.Text
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  admin User @relation("AdminActions", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

// ─── System Settings ─────────────────────────────────────

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ─── Suspicious Events ───────────────────────────────────

model SuspiciousEvent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  eventType   String   @map("event_type") // RAPID_GEO_LOGIN, REPEATED_THIRD_DEVICE, etc.
  details     Json?
  ipAddresses Json?    @map("ip_addresses")
  countries   Json?
  actionTaken String?  @map("action_taken")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("suspicious_events")
}

// ─── Streak Rewards ──────────────────────────────────────

model StreakReward {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  milestone   Int      // 7, 14, 30, 60, 100, etc.
  rewardType  String   @map("reward_type") // XP_BOOST, BADGE, THEME_UNLOCK
  claimedAt   DateTime @default(now()) @map("claimed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@map("streak_rewards")
}

// ─── Achievements ────────────────────────────────────────

model Achievement {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String   // FIRST_WORD, TEN_WORDS, PERFECT_STAGE, SPEED_DEMON
  metadata    Json?
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("achievements")
}

// ─── Challenges ──────────────────────────────────────────

model Challenge {
  id           String   @id @default(uuid())
  challengerId String   @map("challenger_id")
  challengedId String   @map("challenged_id")
  wordId       String   @map("word_id")
  status       String   @default("PENDING") // PENDING, ACCEPTED, COMPLETED, DECLINED
  challengerScore Int?     @map("challenger_score")
  challengedScore Int?     @map("challenged_score")
  createdAt    DateTime @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  challenger   User     @relation("Challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged   User     @relation("Challenged", fields: [challengedId], references: [id], onDelete: Cascade)
  word         Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([challengerId])
  @@index([challengedId])
  @@map("challenges")
}

// ─── Notifications ───────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // CHALLENGE_RECEIVED, CHALLENGE_COMPLETED, FRIEND_JOINED
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}
