generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String            @id @default(uuid())
  firebaseUid        String            @unique @map("firebase_uid")
  email              String            @unique
  name               String?
  avatarUrl          String?           @map("avatar_url")
  dob                DateTime?         @db.Date
  age                Int?
  nationality        String?
  phone              String?
  profession         String?
  reason             String?
  plan               UserPlan          @default(FREE)
  role               UserRole          @default(USER)
  stripeCustomerId   String?           @map("stripe_customer_id")
  stripePaymentId    String?           @map("stripe_payment_id")
  onboardingComplete Boolean           @default(false) @map("onboarding_complete")
  dayCount           Int               @default(0) @map("day_count")
  currentStreak      Int               @default(0) @map("current_streak")
  longestStreak      Int               @default(0) @map("longest_streak")
  totalScore         Int               @default(0) @map("total_score")
  wordsLearned       Int               @default(0) @map("words_learned")
  isLocked           Boolean           @default(false) @map("is_locked")
  lockReason         String?           @map("lock_reason")
  rulesAcknowledged  Boolean           @default(false) @map("rules_acknowledged")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  maxUnlockedIndex   Int               @default(0) @map("max_unlocked_index")
  achievements       Achievement[]
  activityLogs       ActivityLog[]
  adminLogs          AdminLog[]        @relation("AdminActions")
  receivedChallenges Challenge[]       @relation("Challenged")
  sentChallenges     Challenge[]       @relation("Challenger")
  dailyWordSets      DailyWordSet[]
  deviceSessions     DeviceSession[]
  feedback           Feedback[]
  follows            Follow[]          @relation("Follower")
  followers          Follow[]          @relation("Following")
  leaderboardEntry   LeaderboardCache?
  notifications      Notification[]
  streakRewards      StreakReward[]
  suspiciousEvents   SuspiciousEvent[]
  wordProgress       WordProgress[]

  @@map("users")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Word {
  id                    String         @id @default(uuid())
  word                  String         @unique
  phonetic              String
  partOfSpeech          String         @map("part_of_speech")
  definition            String
  tenseForms            Json           @map("tense_forms")
  pronunciationAudioUrl String?        @map("pronunciation_audio_url")
  definitionAudioUrl    String?        @map("definition_audio_url")
  synonyms              Json
  antonyms              Json
  sentences             Json
  articles              Json
  paragraph             String
  audioClipUrls         Json           @map("audio_clip_urls")
  correctAudioCounts    Json           @map("correct_audio_counts")
  paragraphTargetCount  Int            @map("paragraph_target_count")
  paragraphSynonymCount Int            @map("paragraph_synonym_count")
  paragraphAntonymCount Int            @map("paragraph_antonym_count")
  orderIndex            Int            @unique @map("order_index")
  createdAt             DateTime       @default(now()) @map("created_at")
  recall1Questions      Json?          @map("recall_1_questions")
  recall2Pairs          Json?          @map("recall_2_pairs")
  challenges            Challenge[]
  feedback              Feedback[]
  wordProgress          WordProgress[]

  @@map("words")
}

model DailyWordSet {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  date           DateTime @db.Date
  wordIds        Json     @map("word_ids")
  completedCount Int      @default(0) @map("completed_count")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_word_sets")
}

model WordProgress {
  id            String             @id @default(uuid())
  userId        String             @map("user_id")
  wordId        String             @map("word_id")
  date          DateTime           @db.Date
  status        WordProgressStatus @default(IN_PROGRESS)
  totalScore    Int                @default(0) @map("total_score")
  currentStage  Int                @default(1) @map("current_stage")
  sessionState  Json?              @map("session_state")
  flaggedStages Json?              @map("flagged_stages")
  startedAt     DateTime           @default(now()) @map("started_at")
  completedAt   DateTime?          @map("completed_at")
  stageScores   StageScore[]
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  word          Word               @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId])
  @@index([startedAt])
  @@map("word_progress")
}

model StageScore {
  id               String       @id @default(uuid())
  wordProgressId   String       @map("word_progress_id")
  stageNumber      Int          @map("stage_number")
  score            Int          @default(0)
  maxScore         Int          @default(10) @map("max_score")
  timeSpentSeconds Int          @default(0) @map("time_spent_seconds")
  attempts         Int          @default(1)
  passed           Boolean      @default(false)
  responseData     Json?        @map("response_data")
  createdAt        DateTime     @default(now()) @map("created_at")
  wordProgress     WordProgress @relation(fields: [wordProgressId], references: [id], onDelete: Cascade)

  @@unique([wordProgressId, stageNumber])
  @@index([wordProgressId])
  @@index([createdAt])
  @@map("stage_scores")
}

model DeviceSession {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  sessionToken    String   @unique @map("session_token")
  deviceName      String   @map("device_name")
  deviceType      String   @map("device_type")
  os              String
  lastActive      DateTime @default(now()) @map("last_active")
  ipAddress       String   @map("ip_address")
  locationCity    String?  @map("location_city")
  locationCountry String?  @map("location_country")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_sessions")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  actionType  String   @map("action_type")
  wordId      String?  @map("word_id")
  stageNumber Int?     @map("stage_number")
  score       Int?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_log")
}

model LeaderboardCache {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  totalScore    Int      @default(0) @map("total_score")
  wordsLearned  Int      @default(0) @map("words_learned")
  currentStreak Int      @default(0) @map("current_streak")
  rank          Int      @default(0)
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leaderboard_cache")
}

model Feedback {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  category    FeedbackCategory
  subject     String           @db.VarChar(100)
  message     String           @db.VarChar(1000)
  wordId      String?          @map("word_id")
  stageNumber Int?             @map("stage_number")
  status      FeedbackStatus   @default(NEW)
  adminNote   String?          @map("admin_note")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  word        Word?            @relation(fields: [wordId], references: [id])

  @@map("feedback")
}

model AdminLog {
  id          String   @id @default(uuid())
  adminUserId String   @map("admin_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  reason      String
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  admin       User     @relation("AdminActions", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model SuspiciousEvent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  eventType   String   @map("event_type")
  details     Json?
  ipAddresses Json?    @map("ip_addresses")
  countries   Json?
  actionTaken String?  @map("action_taken")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("suspicious_events")
}

model StreakReward {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  milestone  Int
  rewardType String   @map("reward_type")
  claimedAt  DateTime @default(now()) @map("claimed_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@map("streak_rewards")
}

model Achievement {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String
  metadata   Json?
  unlockedAt DateTime @default(now()) @map("unlocked_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("achievements")
}

model Challenge {
  id              String    @id @default(uuid())
  challengerId    String    @map("challenger_id")
  challengedId    String    @map("challenged_id")
  wordId          String    @map("word_id")
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")
  challengedScore Int?      @map("challenged_score")
  challengerScore Int?      @map("challenger_score")
  challenged      User      @relation("Challenged", fields: [challengedId], references: [id], onDelete: Cascade)
  challenger      User      @relation("Challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  word            Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([challengerId])
  @@index([challengedId])
  @@map("challenges")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

enum UserPlan {
  FREE
  PRO
}

enum UserRole {
  USER
  ADMIN
}

enum WordProgressStatus {
  IN_PROGRESS
  RETRY
  COMPLETED
  FAILED
}

enum FeedbackCategory {
  BUG_REPORT
  FEATURE_REQUEST
  STAGE_FEEDBACK
  GENERAL
  OTHER
}

enum FeedbackStatus {
  NEW
  IN_REVIEW
  RESOLVED
  DISMISSED
}
